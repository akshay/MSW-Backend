// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entity {
  id          String   @default(uuid()) @db.Text
  environment String   @db.Text // Environment (staging/production)
  entityType  String   @map("entity_type") @db.Text
  worldId     Int      @map("world_id")
  attributes  Json
  rankScores  Json?    @map("rank_scores") // JSONB key-value map for ranking
  version     Int      @default(1) // Version number for entity, incremented on each update
  isDeleted   Boolean  @default(false) @map("is_deleted") // Soft delete flag
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Composite primary key for efficient lookups with environment isolation
  @@id([environment, entityType, id])

  // GIN index for name-based JSONB queries within entity type
  @@index([attributes], type: Gin, name: "idx_entity_attributes")

  // GIN index for rank scores JSONB queries
  @@index([rankScores], type: Gin, name: "idx_entity_rank_scores")

  // Composite index for environment, entity type and world queries
  @@index([environment, entityType, worldId], name: "idx_entity_env_type_world")

  // Index for version-based queries
  @@index([environment, entityType, id, version], name: "idx_entity_version")

  // Index for filtering deleted entities
  @@index([environment, entityType, worldId, isDeleted], name: "idx_entity_deleted")

  @@map("entities")
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Text
  timestamp       DateTime @default(now())
  
  worldInstanceId String?  @map("world_instance_id") @db.Text
  clientIp        String?  @map("client_ip") @db.Text
  environment     String?  @db.Text
  
  commandType     String   @map("command_type") @db.Text
  commandIndex    Int      @map("command_index")
  
  entityType      String?  @map("entity_type") @db.Text
  entityId        String?  @map("entity_id") @db.Text
  worldId         Int?     @map("world_id")
  
  inputData       Json?    @map("input_data")
  outputData      Json?    @map("output_data")
  
  statusCode      Int      @map("status_code")
  durationMs      Int      @map("duration_ms")
  success         Boolean  @default(true)
  errorMessage    String?  @map("error_message") @db.Text
  
  method          String   @db.Text
  path            String   @db.Text
  
  @@index([timestamp])
  @@index([commandType, timestamp])
  @@index([entityType, timestamp])
  @@index([worldInstanceId, timestamp])
  @@index([environment, timestamp])
  @@index([success, timestamp])
  
  @@map("audit_logs")
}
