# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/msw_backend

# Redis
CACHE_REDIS_URL=redis://localhost:6379
EPHEMERAL_REDIS_URL=redis://localhost:6379
STREAM_REDIS_URL=redis://localhost:6379

# Authentication Keys (Base64 encoded)
SENDER_PUBLIC_KEY=base64_encoded_public_key_here
RECIPIENT_PRIVATE_KEY=base64_encoded_private_key_here

# Backblaze B2 Configuration
BACKBLAZE_KEY_ID=your_backblaze_key_id_here
BACKBLAZE_KEY=your_backblaze_key_here
BACKBLAZE_STAGING_BUCKET=your_backblaze_bucket_name_here
BACKBLAZE_PRODUCTION_BUCKET=your_backblaze_bucket_name_here

# Backblaze File Sync Settings (optional)
FILE_SYNC_INTERVAL_MS=60000
FILE_SYNC_ENABLED=true

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Settings (optional)
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=10000

# Ephemeral Entity Settings (optional)
EPHEMERAL_VERSION_CACHE_TTL_SECONDS=3600
EPHEMERAL_BATCH_SIZE=5000

# Background Persistence Settings (optional)
BG_PERSISTENCE_LOCK_TTL_SECONDS=10
BG_PERSISTENCE_BATCH_SIZE=500
BG_PERSISTENCE_INTERVAL_MS=5000
BG_PERSISTENCE_MAX_RETRIES=3
BG_PERSISTENCE_RETRY_DELAY_MS=1000

# Persistent Entity Settings (optional)
PERSISTENT_BATCH_SIZE=5000

# Stream Settings (optional)
STREAM_WORLD_INSTANCE_TTL_SECONDS=3

# Distributed Lock Settings (optional)
LOCK_DEFAULT_TTL_SECONDS=10
LOCK_RETRY_DELAY_MS=100
LOCK_MAX_RETRIES=3

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Enable automated backups (set to 'true' in production)
# Default: false
BACKUP_ENABLED=true

# Cron schedule for automated backups
# Default: every 6 hours (00:00, 06:00, 12:00, 18:00)
# Examples:
#   "0 */6 * * *"  - Every 6 hours
#   "0 */4 * * *"  - Every 4 hours  
#   "0 2 * * *"    - Daily at 2 AM
#   "0 2,14 * * *" - Twice daily (2 AM and 2 PM)
BACKUP_SCHEDULE="0 */6 * * *"

# Number of days to retain backups (older backups auto-deleted)
# Default: 7 days
# Recommended: 7-30 days depending on storage budget
BACKUP_RETENTION_DAYS=7

# Gzip compression level (1-9)
# 1 = fastest, 9 = smallest, 6 = balanced (recommended)
BACKUP_COMPRESSION_LEVEL=6

# Backblaze B2 bucket for backups
# Defaults to BACKBLAZE_PRODUCTION_BUCKET if not specified
# Create a separate bucket for backups if you want isolation
BACKBLAZE_BACKUP_BUCKET=

# Temporary directory for backup operations
# Must have sufficient disk space (at least 2x largest backup size)
# Default: /tmp/msw-backups
BACKUP_TEMP_DIR=/tmp/msw-backups

# Backup worker HTTP health endpoint port
# Used for monitoring backup worker health
# Default: 3001
BACKUP_WORKER_PORT=3001

# Number of days to keep backup worker logs
# PM2 will rotate logs older than this
# Default: 7 days (matches BACKUP_RETENTION_DAYS)
BACKUP_LOG_RETENTION_DAYS=7
